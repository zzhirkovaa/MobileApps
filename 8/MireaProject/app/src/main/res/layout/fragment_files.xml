<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/filesRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/filesScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="96dp">

            <TextView
                android:id="@+id/textViewFilesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/files_title"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/textViewFilesDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/files_description"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <EditText
                android:id="@+id/editTextLoadFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/files_file_name_hint"
                android:inputType="text"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/buttonLoadFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/files_load_button"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/textViewEncryptedLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/files_encrypted_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewEncryptedResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Здесь появится зашифрованный текст"
                android:textSize="16sp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/textViewDecryptedLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/files_decrypted_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textViewDecryptedResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Здесь появится расшифрованный текст"
                android:textSize="16sp" />

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreateFileRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="@string/files_dialog_title"
        app:srcCompat="@android:drawable/ic_input_add" />

</FrameLayout>